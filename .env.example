# ============================================================
# SusuVault / HaloSave — Environment Variables
# Copy this file to .env (local) or set these in Railway → Variables.
# ============================================================

# --- REQUIRED: Auth signing secret ---
# The server REFUSES TO BOOT without a strong value (min 16 chars).
# Generate one with:  openssl rand -hex 32
JWT_SECRET=""

# --- REQUIRED: Database ---
# Railway/Supabase give you a single connection string. Use it directly.
# Railway: copy the "DATABASE_URL" (or "Postgres Connection URL") from the DB service.
DATABASE_URL=""
# Set to "true" ONLY if your DB explicitly does not use SSL (rare on managed hosts).
PGSSL_DISABLE="false"

# --- Local dev only (used if DATABASE_URL is not set) ---
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="password"
SQL_DB_NAME="halosave_vault"

# --- Runtime ---
NODE_ENV="production"
# Railway sets PORT automatically — do NOT hardcode it.
# Lock CORS to your deployed origin(s), comma-separated. Leave empty to allow same-origin.
ALLOWED_ORIGIN=""
# Public base URL of the deployed app (used for Paystack callbacks).
APP_URL=""

# --- Paystack (payments) ---
PAYSTACK_SECRET_KEY=""
VITE_PAYSTACK_PUBLIC_KEY=""

# --- Supabase Auth (optional — leave blank to use built-in local JWT auth) ---
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# --- Gemini AI Coach (optional) ---
GEMINI_API_KEY=""

# --- Seeded super admin (used by `npm run db:seed`) ---
# If SEED_ADMIN_PASSWORD is left blank, a strong random password is generated
# and printed once in the seed output. There is NO hardcoded default password.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_NAME=""
SEED_ADMIN_PASSWORD=""
# Set to "false" to skip the demo vaults/tranches in production seeds.
SEED_DEMO_DATA="true"

# --- Fund NAV automation (optional) ---
# Leave blank to manage NAVs manually via the admin endpoint. If you wire a real
# source in src/server/services/navFetcher.ts, configure it here.
NAV_SOURCE_URL=""
NAV_SOURCE_KEY=""
